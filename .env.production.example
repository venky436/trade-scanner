# ===========================================
# Trading Scanner — Production Environment
# ===========================================
# Copy this file to .env on your droplet:
#   cp .env.production.example .env
#
# Replace YOUR_DROPLET_IP with your actual IP

# --- Kite API ---
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=

# --- Market mode ---
MARKET_MODE=commodity

# --- URLs (replace YOUR_DROPLET_IP) ---
FRONTEND_URL=http://YOUR_DROPLET_IP:3000
NEXT_PUBLIC_API_URL=http://YOUR_DROPLET_IP:4000
NEXT_PUBLIC_WS_URL=ws://YOUR_DROPLET_IP:4000/ws

# --- Database ---
POSTGRES_PASSWORD=change_me_in_production
